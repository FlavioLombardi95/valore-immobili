# Google Sheet (obbligatorio per lettura e scrittura)
# ID del foglio: dall'URL https://docs.google.com/spreadsheets/d/QUESTO_È_LO_SHEET_ID/edit
GOOGLE_SHEET_ID=

# Solo per scrittura lead (form): JSON della Service Account (Google Cloud)
# Crea un progetto su Google Cloud > API e servizi > Credenziali > Account di servizio
# Scarica la chiave JSON e incollala qui (o in Vercel come variabile segreta)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Opzionale: nome foglio (default "Foglio 1")
# GOOGLE_SHEET_NAME=Foglio 1

# Opzionale: gid del foglio per GET /api/sheet (default "0")
# GOOGLE_SHEET_GID=0
