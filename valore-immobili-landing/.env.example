# URL della Privacy Policy su Iubenda (Direct link).
# Dal dashboard Iubenda: Privacy and Cookie Policy → Embed → Direct link.
# Es: https://www.iubenda.com/privacy-policy/69451858
VITE_IUBENDA_PRIVACY_URL=https://www.iubenda.com/privacy-policy/69451858

# Twilio Lookup API (telefono)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kickbox Email Verification API
KICKBOX_API_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opzionale: inoltro lead al backend esistente (Google Sheet, CRM, ecc.)
LEAD_FORWARD_URL=https://example.com/api/lead

# Numero WhatsApp usato dal redirect server-side /api/wa-link
WHATSAPP_NUMBER=393516349175

# In alternativa a LEAD_FORWARD_URL: salvataggio diretto su Google Sheet
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Opzionale: nome tab specifico (es. Foglio 1)
# GOOGLE_SHEET_NAME=Foglio 1
